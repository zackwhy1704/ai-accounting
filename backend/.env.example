# Database (PostgreSQL - works with local, Supabase, or AWS RDS)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_account

# Security
SECRET_KEY=your-secret-key-change-in-production

# Storage (local or s3)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads
# S3_BUCKET_NAME=ai-account-documents
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=  # For MinIO/Supabase

# Azure Document Intelligence (OCR)
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Celery (async queue - Redis for now, SQS for AWS migration)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
